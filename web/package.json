{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "tokens": "node scripts/build-m3-tokens.mjs",
    "check:no-em-dash": "node scripts/check-no-em-dash.mjs",
    "check:visual": "node test/visual/full-audit.mjs",
    "check:patterns": "node test/visual/pattern-audit.mjs --check",
    "snap:patterns": "node test/visual/pattern-audit.mjs",
    "update:patterns-baseline": "node test/visual/pattern-audit.mjs --update",
    "prebuild": "npm run tokens && npm run check:no-em-dash",
    "predev": "npm run tokens",
    "check:a11y": "node test/visual/a11y-audit.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@material/material-color-utilities": "^0.3.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/web-bluetooth": "^0.0.21",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "autoprefixer": "^10.5.0",
    "axe-core": "^4.11.4",
    "postcss": "^8.5.13",
    "svelte": "^5.55.7",
    "svelte-check": "^4.4.7",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@types/three": "^0.184.1",
    "buffer": "^6.0.3",
    "jpeg-js": "^0.4.4",
    "qrcode": "^1.5.4",
    "three": "^0.184.0"
  }
}
